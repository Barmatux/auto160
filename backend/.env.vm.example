POSTGRES_DB=auto160
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-db-password

DATABASE_URL=postgresql+psycopg2://postgres:change-me-db-password@db:5432/auto160
SECRET_KEY=change-me-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_MINUTES=10080

BOOTSTRAP_ADMIN_EMAIL=admin@auto160.com
BOOTSTRAP_ADMIN_LOGIN=admin
BOOTSTRAP_ADMIN_NAME=Auto160 Admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password

CATALOG_SEED_CSV_PATH=app/data/catalog_u160_audi_bmw_mini.csv

S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=auto160-media
S3_REGION=us-east-1
S3_PRESIGN_EXPIRES_SECONDS=3600

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio-password

# Optional: auto-solve av.by reCAPTCHA when registering service accounts (2captcha / rucaptcha)
# CAPTCHA_2CAPTCHA_API_KEY=your-2captcha-api-key
# CAPTCHA_API_URL=https://2captcha.com

# Optional: personal av.by account for VIN testing (30 checks/day, not committed)
# AVBY_VIN_TEST_EMAIL=your@gmail.com
# AVBY_VIN_TEST_PASSWORD=your-password
# Or use data/avby_vin_test_credentials.json on the server (gitignored)

# Optional: HeroSMS virtual numbers for av.by phone verification (+375)
# HERO_SMS_API_KEY=your-hero-sms-api-key

# Optional: Weeek task board integration
# WEEEK_API_TOKEN=your-weeek-api-token

# Logging (files mounted to ~/auto160/logs on VM)
# LOG_DIR=/app/logs
# LOG_LEVEL=INFO
